{
  "name": "rasicross-telemetry",
  "version": "9.6.0",
  "description": "RasiCross Telemetry \u2013 ESP-NOW USB Dashboard",
  "main": "main.js",
  "author": "RasiCross",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build-portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rasicross.telemetry",
    "productName": "RasiCross Telemetry",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "RasiCross_Telemetry.html",
      "rasicross.js",
      "geo.js",
      "replay.js",
      "karts3d.js",
      "vendor/**",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "drivers/",
        "to": "drivers/",
        "filter": [
          "**/*.exe",
          "**/*.EXE"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "RasiCross Telemetry",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "installer.nsh",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "artifactName": "RasiCross-Telemetry-Setup.${ext}"
    },
    "portable": {
      "artifactName": "RasiCross-Telemetry-Portable.${ext}",
      "requestExecutionLevel": "user"
    },
    "mac": {
      "target": [
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "gatekeeperAssess": false,
      "artifactName": "RasiCross-Telemetry-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Utility",
      "synopsis": "Live-Telemetrie-Dashboard fuer ESP32-Kart-Sender"
    },
    "npmRebuild": true
  },
  "dependencies": {
    "serialport": "^13.0.0",
    "@serialport/parser-readline": "^13.0.0"
  }
}