{
  "name": "rasicross-telemetry",
  "version": "1.0.7",
  "description": "RasiCross Telemetry – ESP-NOW USB Dashboard",
  "main": "main.js",
  "author": "RasiCross",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "lint": "eslint .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build-portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.5.0",
    "globals": "^17.7.0"
  },
  "build": {
    "appId": "com.rasicross.telemetry",
    "productName": "RasiCross Telemetry",
    "publish": {
      "provider": "github",
      "owner": "Lutji06",
      "repo": "RasiCross-Telemetrie"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "RasiCross_Telemetry.html",
      "rasicross.js",
      "map-draw.js",
      "races.js",
      "serial-demo.js",
      "gauges.js",
      "track.js",
      "laps-drivers.js",
      "live-ui.js",
      "pit-wall.js",
      "recording.js",
      "kart-registry.js",
      "kart-bar.js",
      "kart-overview.js",
      "geo.js",
      "replay.js",
      "lap-engine.js",
      "drift.js",
      "attitude.js",
      "karts3d.js",
      "tiles.js",
      "tile-renderer.js",
      "dom-targets.js",
      "settings.js",
      "engine.js",
      "rec-store.js",
      "vendor/**",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "drivers/",
        "to": "drivers/",
        "filter": [
          "**/*.exe",
          "**/*.EXE"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "RasiCross Telemetry",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "installer.nsh",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "artifactName": "RasiCross-Telemetry-Setup.${ext}"
    },
    "portable": {
      "artifactName": "RasiCross-Telemetry-Portable.${ext}",
      "requestExecutionLevel": "user"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "gatekeeperAssess": false,
      "artifactName": "RasiCross-Telemetry-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "synopsis": "Live-Telemetrie-Dashboard fuer ESP32-Kart-Sender"
    },
    "npmRebuild": false
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "electron-updater": "^6.8.9",
    "serialport": "^13.0.0"
  }
}
